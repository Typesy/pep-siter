NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
# Controls endpoint selection in app code:
# sandbox    -> API https://apitest.authorize.net/xml/v1/request.api
#               Hosted form https://test.authorize.net/payment/payment
# production -> API https://api.authorize.net/xml/v1/request.api
#               Hosted form https://accept.authorize.net/payment/payment
AUTHORIZE_NET_ENVIRONMENT=sandbox
AUTHORIZE_NET_MERCHANT_NAME=
AUTHORIZE_NET_WEBHOOK_SIGNATURE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
